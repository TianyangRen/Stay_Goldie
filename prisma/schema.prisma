// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(OWNER)
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  pets          Pet[]     @relation("OwnerPets")
  bookings      Booking[]
  orders        Order[]
  blogPosts     BlogPost[]
  postingPersonas PostingPersona[]
  blogPostLikes   BlogPostLike[]
  blogPostComments BlogPostComment[]
}

/** Admin-only "voice" for updates: post as a named pet with its own avatar. */
model PostingPersona {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  avatarUrl String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts     BlogPost[]

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ProcessedStripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model Pet {
  id              String             @id @default(cuid())
  ownerId         String
  owner           User               @relation("OwnerPets", fields: [ownerId], references: [id])
  name            String
  breed           String?
  sizeTier        String?
  birthDate       DateTime?
  avatarUrl       String?
  createdAt       DateTime           @default(now())
  posts           PetPost[]
  healthProfile   PetHealthProfile?
  bookingPets     BookingPet[]
}

model PetHealthProfile {
  id                    String                @id @default(cuid())
  petId                  String                @unique
  pet                    Pet                   @relation(fields: [petId], references: [id])
  dietRestrictions       String?
  medications            String?
  socialBehavior         String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  vetName                String?
  vetPhone               String?
  notes                  String?
  vaccineDocuments       PetVaccineDocument[]
  preferredClinics       PetClinic[]
  updatedAt              DateTime              @updatedAt
}

model PetVaccineDocument {
  id           String   @id @default(cuid())
  profileId    String
  profile      PetHealthProfile @relation(fields: [profileId], references: [id])
  fileUrl      String
  fileName     String
  mimeType     String?
  uploadedAt   DateTime @default(now())
}

model PetClinic {
  id          String   @id @default(cuid())
  profileId   String
  profile     PetHealthProfile @relation(fields: [profileId], references: [id])
  clinicName  String
  phone       String?
  address     String?
  notes       String?
}

model Booking {
  id                 String        @id @default(cuid())
  ownerId            String
  owner              User          @relation(fields: [ownerId], references: [id])
  checkInDate        DateTime
  checkOutDate       DateTime
  nightlyRateCad     Decimal       @db.Decimal(10, 2)
  estimatedTotalCad  Decimal       @db.Decimal(10, 2)
  depositCad         Decimal       @db.Decimal(10, 2)
  stripeSessionId    String?       @unique
  status             BookingStatus @default(PENDING)
  notes              String?
  createdAt          DateTime      @default(now())
  pets               BookingPet[]
}

model BookingPet {
  bookingId String
  petId     String
  booking   Booking @relation(fields: [bookingId], references: [id])
  pet       Pet     @relation(fields: [petId], references: [id])

  @@id([bookingId, petId])
}

model Product {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String
  imageUrl       String?
  basePriceCad   Decimal     @db.Decimal(10, 2)
  salePriceCad   Decimal?    @db.Decimal(10, 2)
  isActive       Boolean     @default(true)
  inventory      Inventory?
  orderItems     OrderItem[]
  createdAt      DateTime    @default(now())
}

model Inventory {
  productId      String   @id
  product        Product  @relation(fields: [productId], references: [id])
  stock          Int
  lowStockLevel  Int      @default(5)
  updatedAt      DateTime @updatedAt
}

model Order {
  id               String      @id @default(cuid())
  ownerId          String
  owner            User        @relation(fields: [ownerId], references: [id])
  status           OrderStatus @default(PENDING)
  subtotalCad      Decimal     @db.Decimal(10, 2)
  totalCad         Decimal     @db.Decimal(10, 2)
  stripeSessionId  String?     @unique
  createdAt        DateTime    @default(now())
  items            OrderItem[]
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPriceCad  Decimal  @db.Decimal(10, 2)
  order         Order    @relation(fields: [orderId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])
}

model PetPost {
  id          String      @id @default(cuid())
  petId        String
  pet          Pet         @relation(fields: [petId], references: [id])
  caption      String
  createdAt    DateTime    @default(now())
  media        PetPostMedia[]
}

model PetPostMedia {
  id          String   @id @default(cuid())
  postId       String
  post         PetPost  @relation(fields: [postId], references: [id])
  mediaUrl     String
  altText      String?
}

model BlogCategory {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  posts    BlogPost[]
}

model BlogPost {
  id           String       @id @default(cuid())
  authorId     String
  author       User         @relation(fields: [authorId], references: [id])
  personaId    String?
  persona      PostingPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  categoryId   String?
  category     BlogCategory? @relation(fields: [categoryId], references: [id])
  title        String
  slug         String       @unique
  excerpt      String
  content      String
  coverImage   String?
  publishedAt  DateTime?
  createdAt    DateTime     @default(now())
  likes        BlogPostLike[]
  comments     BlogPostComment[]

  @@index([authorId])
  @@index([personaId])
}

model BlogPostLike {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model BlogPostComment {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
}
